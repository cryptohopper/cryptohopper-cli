{
  "name": "@cryptohopper/cli",
  "version": "0.5.0-alpha.1",
  "description": "Command-line interface for Cryptohopper",
  "type": "module",
  "bin": {
    "cryptohopper": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "compile:linux-x64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-linux-x64 --outfile=dist/cryptohopper-linux-x64",
    "compile:darwin-x64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-darwin-x64 --outfile=dist/cryptohopper-darwin-x64",
    "compile:darwin-arm64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-darwin-arm64 --outfile=dist/cryptohopper-darwin-arm64",
    "compile:windows-x64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-windows-x64 --outfile=dist/cryptohopper-windows-x64.exe",
    "compile:all": "npm run compile:linux-x64 && npm run compile:darwin-x64 && npm run compile:darwin-arm64 && npm run compile:windows-x64"
  },
  "dependencies": {
    "@cryptohopper/sdk": "^0.4.0-alpha.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsup": "^8",
    "typescript": "^6"
  },
  "engines": { "node": ">=20" },
  "keywords": ["cryptohopper", "cli", "trading", "crypto"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cryptohopper/cryptohopper-cli.git"
  },
  "homepage": "https://www.cryptohopper.com",
  "bugs": "https://github.com/cryptohopper/cryptohopper-cli/issues"
}
